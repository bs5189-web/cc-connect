# Copy this file to .env before running docker compose.

TZ=Asia/Shanghai

# cc-connect external ports.
CC_CONNECT_BRIDGE_PORT=9810
CC_CONNECT_MANAGEMENT_PORT=9820
CC_CONNECT_WEBHOOK_PORT=9111

# Bind the project you want Codex to work on into the container at /workspace.
# Use an absolute path for real deployments, for example:
# CC_CONNECT_WORKSPACE=/Users/me/work/my-project
CC_CONNECT_WORKSPACE=./workspace

# Optional: pin Codex CLI during image builds.
CODEX_NPM_PACKAGE=@openai/codex@latest

# Optional on Linux: set these to `id -u` and `id -g` so mounted files are writable.
CC_CONNECT_UID=1000
CC_CONNECT_GID=1000

# Provider credentials used by docker/cc-connect/config.toml.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Example platform credential. Change config.toml if you use Feishu/Lark,
# Slack, Discord, DingTalk, WeCom, WeChat, QQ, LINE, or Weibo instead.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOW_FROM=
